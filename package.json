{
  "name": "@code-fixer-23/cn-efs",
  "version": "1.0.0",
  "description": "This is the repo for creating a Class Name Filter Sorter",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vitest",
    "dev:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "release": "tsup && dotenv release-it"
  },
  "license": "ISC",
  "devDependencies": {
    "@release-it/keep-a-changelog": "^4.0.0",
    "@total-typescript/ts-reset": "^0.5.1",
