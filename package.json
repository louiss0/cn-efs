    "@vitest/ui": "^0.34.4",
    "dotenv-cli": "^7.3.0",
    "eslint": "^8.49.0",
    "release-it": "^16.2.0",
    "tsup": "^7.2.0",
    "typescript": "^5.2.2",
    "vite": "^4.4.9",
    "vitest": "^0.34.4"
  },
  "keywords": [
    "tailwindcss",
    "unocss",
    "css",
    "className",
    "classList",
    "windicss"
  ],
  "author": {
    "name": "Shelton Louis",
    "url": "https://github.com/louiss0"
  },
